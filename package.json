{
  "name": "9router-plus",
  "version": "0.5.0",
  "description": "9Router Plus - Enhanced AI Router with Go Proxy Runtime",
  "private": false,
  "scripts": {
    "dev": "next dev --webpack --port 20128",
    "build:web": "NODE_ENV=production next build --webpack",
    "build:go-proxy": "sh -c 'mkdir -p bin && cd go-proxy && go build -o ../bin/9router-go-proxy .'",
    "verify:go-proxy-bin": "sh -c 'test -x bin/9router-go-proxy && (./bin/9router-go-proxy --help >/dev/null 2>&1 || ./bin/9router-go-proxy -h >/dev/null 2>&1 || true)'",
    "install:go-proxy": "sh -c 'mkdir -p \"$HOME/.9router/bin\" && cp bin/9router-go-proxy \"$HOME/.9router/bin/9router-go-proxy\" && chmod +x \"$HOME/.9router/bin/9router-go-proxy\"'",
    "build": "npm run build:go-proxy && npm run build:web",
    "start": "NODE_ENV=production node ./scripts/start.js",
    "start:with-go-wrapper": "GO_PROXY_WRAPPER_ENABLED=true NODE_ENV=production node ./scripts/start.js",
    "go-proxy:test": "sh -c 'cd go-proxy && go test ./...'",
    "test": "npm --prefix tests test",
    "dev:bun": "bun --bun next dev --webpack --port 20128",
    "build:bun": "NODE_ENV=production bun --bun next build --webpack",
    "start:bun": "NODE_ENV=production bun ./.next/standalone/server.js"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@xyflow/react": "^12.10.1",
    "bcryptjs": "^3.0.3",
    "confbox": "^0.2.4",
    "express": "^5.2.1",
    "fs": "^0.0.1-security",
    "got-scraping": "^4.2.1",
    "http-proxy-middleware": "^3.0.5",
    "jose": "^6.1.3",
    "lowdb": "^7.0.1",
    "marked": "^18.0.1",
    "monaco-editor": "^0.55.1",
    "next": "^16.1.6",
    "node-forge": "^1.3.3",
    "node-machine-id": "^1.1.12",
    "open": "^11.0.0",
    "ora": "^9.1.0",
    "proper-lockfile": "^4.1.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-is": "^16.13.1",
    "recharts": "^3.7.0",
    "redis": "^5.12.1",
    "selfsigned": "^5.5.0",
    "socks-proxy-agent": "^8.0.5",
    "sql.js": "^1.14.1",
    "undici": "^7.19.2",
    "uuid": "^13.0.0",
    "zustand": "^5.0.10"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.6.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "postcss": "^8.5.6",
    "tailwindcss": "^4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rickicode/9router.git"
  },
  "keywords": [
    "ai-router",
    "llm-proxy",
    "openai",
    "claude",
    "gemini",
    "go-proxy",
    "smart-fallback",
    "rate-limiting"
  ],
  "author": "rickicode",
  "license": "MIT",
  "homepage": "https://github.com/rickicode/9router#readme"
}
